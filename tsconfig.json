{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "strict": true,
    "module": "ES2022",
    "target": "ES2020",
    "lib": ["ES2023"],
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "ags/lib/gtk4",
    "paths": {
      "gi://*": ["./node_modules/ags/@girs/*"],
      "ags/*": ["./node_modules/ags/lib/*"],
      "gnim": ["./node_modules/gnim/dist/index.d.ts"],
      "gnim/*": ["./node_modules/gnim/dist/*"]
    }
  }
}